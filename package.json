{
  "name": "forgedocs",
  "version": "0.3.2",
  "description": "Architecture documentation framework for codebases. Auto-discovers repos, renders docs with VitePress, and maintains them with AI-assisted commands.",
  "type": "module",
  "license": "MIT",
  "author": "Nicolas Laporte",
  "repository": {
    "type": "git",
    "url": "https://github.com/laport-n/forgedocs.git"
  },
  "homepage": "https://github.com/laport-n/forgedocs",
  "bugs": {
    "url": "https://github.com/laport-n/forgedocs/issues"
  },
  "bin": {
    "forgedocs": "bin/forgedocs.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "templates/",
    ".vitepress/config.ts",
    "index.md",
    "docsite.config.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "documentation",
    "architecture",
    "vitepress",
    "adr",
    "claude-code",
    "ai-agents",
    "docs-as-code",
    "architecture-decision-records",
    "docforge"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "docs": "node scripts/setup.mjs --check && vitepress dev",
    "docs:dev": "node scripts/setup.mjs --check && vitepress dev",
    "docs:build": "node scripts/setup.mjs --check && vitepress build",
    "docs:preview": "vitepress preview",
    "install-commands": "node scripts/install-commands.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "vitepress": "^1.6.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.2"
  }
}
